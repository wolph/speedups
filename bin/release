#!/usr/bin/env python3
"""Interactive release script with version bump menu
and LLM commit messages."""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile

try:
    import questionary
    from rich.console import Console
    from rich.panel import Panel
except ImportError:
    print(
        "Error: 'rich' and 'questionary' are required. Install with:\n"
        '  uv pip install rich questionary\n'
        '  pip install rich questionary',
        file=sys.stderr,
    )
    raise SystemExit(1) from None

# ---------------------------------------------------------------------------
# Configuration — change these when adopting in another project
# ---------------------------------------------------------------------------

DEVELOP_BRANCH = 'develop'
MAIN_BRANCH = 'master'

COMMIT_PROMPT_TEMPLATE = """\
Summarize the following git commit messages into a concise release commit
message. The version being released is {version} (previously {old_version}).
Focus on user-facing changes. Use conventional commit style.
Output ONLY the commit message, no extra commentary.
Make sure to properly attribute the authors of pull requests and the commits.

Commits:
{commits}
"""

# ---------------------------------------------------------------------------
# Rich console
# ---------------------------------------------------------------------------

console = Console()

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------


def die(msg: str) -> None:
    """Print a red error message and exit."""
    console.print(f'[bold red]Error:[/bold red] {msg}', highlight=False)
    raise SystemExit(1)


def info(msg: str) -> None:
    """Print a blue info message."""
    console.print(f'[bold blue]==>[/bold blue] {msg}', highlight=False)


def ok(msg: str) -> None:
    """Print a green success message."""
    console.print(f'[bold green]==>[/bold green] {msg}', highlight=False)


# ---------------------------------------------------------------------------
# Subprocess helpers
# ---------------------------------------------------------------------------


def run(
    cmd: list[str],
    *,
    capture: bool = False,
    check: bool = True,
    stdin_data: str | None = None,
    timeout: int | None = None,
) -> subprocess.CompletedProcess[str]:
    """Run a command via subprocess."""
    return subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
        check=check,
        input=stdin_data,
        timeout=timeout,
    )


def git(
    *args: str, capture: bool = False, check: bool = True
) -> subprocess.CompletedProcess[str]:
    """Run a git command."""
    return run(['git', *args], capture=capture, check=check)


def uv(
    *args: str, capture: bool = False, check: bool = True
) -> subprocess.CompletedProcess[str]:
    """Run a uv command."""
    return run(['uv', *args], capture=capture, check=check)


# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------


def preflight_checks(*, dry_run: bool = False) -> None:
    """Validate branch, working tree, and tool availability."""
    # Check uv is available
    if not shutil.which('uv'):
        die("'uv' is not installed or not in PATH")

    # Check branch
    result = git('symbolic-ref', '--short', 'HEAD', capture=True)
    branch = result.stdout.strip()
    if branch != DEVELOP_BRANCH:
        die(f"Must be on '{DEVELOP_BRANCH}' branch (currently on '{branch}')")

    if dry_run:
        return

    # Check clean working tree
    diff_result = run(
        ['git', 'diff', '--quiet'],
        check=False,
    )
    cached_result = run(
        ['git', 'diff', '--cached', '--quiet'],
        check=False,
    )
    if diff_result.returncode != 0 or cached_result.returncode != 0:
        die('Working tree is dirty — commit or stash changes first')

    # Fetch main and verify ff-only merge is possible before we
    # make any changes.  This avoids bumping the version and then
    # discovering the merge will fail.
    info(f'Fetching {MAIN_BRANCH} from origin...')
    git('fetch', 'origin', MAIN_BRANCH)

    merge_base = git(
        'merge-base',
        f'origin/{MAIN_BRANCH}',
        DEVELOP_BRANCH,
        capture=True,
    ).stdout.strip()
    main_tip = git(
        'rev-parse',
        f'origin/{MAIN_BRANCH}',
        capture=True,
    ).stdout.strip()

    if merge_base != main_tip:
        die(
            f'{MAIN_BRANCH} has commits not in {DEVELOP_BRANCH}. '
            f'Rebase first:\n'
            f'  git rebase origin/{MAIN_BRANCH}'
        )


# ---------------------------------------------------------------------------
# Version helpers
# ---------------------------------------------------------------------------


def get_current_version() -> str:
    """Read current version from pyproject.toml via uv."""
    result = uv('version', '--short', capture=True)
    return result.stdout.strip()


def preview_bump(bump_args: list[str]) -> str:
    """Preview what version a bump would produce, without writing.

    Returns the new version string.
    Raises SystemExit if the bump combination is invalid.
    """
    cmd = ['uv', 'version']
    for arg in bump_args:
        cmd.extend(['--bump', arg])
    cmd.append('--dry-run')

    result = run(cmd, capture=True, check=False)
    if result.returncode != 0:
        # uv prints the error to stderr
        die(f'Invalid version bump: {result.stderr.strip()}')

    # Output format: "package X.Y.Z => A.B.C"
    line = result.stdout.strip()
    return line.split('=>')[-1].strip()


def apply_bump(bump_args: list[str]) -> str:
    """Apply a version bump and return the new version."""
    cmd = ['uv', 'version']
    for arg in bump_args:
        cmd.extend(['--bump', arg])
    cmd.append('--frozen')

    result = run(cmd, capture=True, check=False)
    if result.returncode != 0:
        die(f'Version bump failed: {result.stderr.strip()}')

    # Read back the actual version to confirm
    return get_current_version()


def set_version(version: str) -> str:
    """Set an explicit version string (for custom input)."""
    uv('version', version, '--frozen', capture=True)
    return get_current_version()


# ---------------------------------------------------------------------------
# Interactive version menu
# ---------------------------------------------------------------------------


def prompt_prerelease_menu(current: str) -> tuple[str, list[str]]:
    """Sub-menu for pre-release version selection.

    Returns (new_version, bump_args).
    """
    components = {'Major': 'major', 'Minor': 'minor', 'Patch': 'patch'}
    component_label = questionary.select(
        'Bump component:',
        choices=list(components),
        default='Minor',
    ).ask()
    if component_label is None:
        die('Aborted')
    component = components[component_label]

    pre_types = {
        'rc (release candidate)': 'rc',
        'beta': 'beta',
        'alpha': 'alpha',
    }
    type_label = questionary.select(
        'Pre-release type:',
        choices=list(pre_types),
        default='rc (release candidate)',
    ).ask()
    if type_label is None:
        die('Aborted')
    pre_type = pre_types[type_label]

    bump_args = [component, pre_type]
    new_version = preview_bump(bump_args)

    console.print(
        f'  Preview: [bold]{current}[/bold] → '
        f'[bold green]{new_version}[/bold green]'
    )

    return new_version, bump_args


def prompt_version_menu(current: str) -> tuple[str, list[str] | None]:
    """Present the main version bump menu.

    Returns (new_version, bump_args).
    bump_args is None when a custom version string was entered.
    """
    # Compute previews for standard bumps
    major_v = preview_bump(['major'])
    minor_v = preview_bump(['minor'])
    patch_v = preview_bump(['patch'])

    # Build choices with aligned version previews
    choices = [
        questionary.Choice(f'Major        →  {major_v}', value='major'),
        questionary.Choice(f'Minor        →  {minor_v}', value='minor'),
        questionary.Choice(f'Patch        →  {patch_v}', value='patch'),
        questionary.Choice('Pre-release  →  (submenu)', value='pre'),
        questionary.Choice('Custom       →  (enter version)', value='custom'),
    ]

    console.print(f'\n  Current version: [bold]{current}[/bold]\n')

    choice = questionary.select(
        'Version bump:',
        choices=choices,
        default=choices[1],  # default to Minor
    ).ask()
    if choice is None:
        die('Aborted')

    bump_map: dict[str, tuple[str, list[str]]] = {
        'major': (major_v, ['major']),
        'minor': (minor_v, ['minor']),
        'patch': (patch_v, ['patch']),
    }

    if choice in bump_map:
        return bump_map[choice][0], bump_map[choice][1]
    elif choice == 'pre':
        return prompt_prerelease_menu(current)
    else:
        custom = questionary.text(
            'Enter PEP 440 version:',
            validate=lambda v: (
                True
                if run(
                    ['uv', 'version', v, '--dry-run'],
                    capture=True,
                    check=False,
                ).returncode
                == 0
                else 'Invalid PEP 440 version'
            ),
        ).ask()
        if custom is None:
            die('Aborted')
        return custom, None


# ---------------------------------------------------------------------------
# LLM commit message generation
# ---------------------------------------------------------------------------

LLM_CLIS: dict[str, list[str]] = {
    'claude': ['claude', '--print', '-p'],
    'codex': ['codex', 'exec'],
    'gemini': ['gemini', '--prompt'],
}


def detect_llm_clis() -> list[str]:
    """Scan PATH for available LLM CLI tools."""
    available = []
    for name in LLM_CLIS:
        if shutil.which(name):
            available.append(name)
    return available


def prompt_llm_menu(available: list[str]) -> str:
    """Let user pick an LLM CLI. Auto-selects if only one is available."""
    if len(available) == 1:
        info(f'Using {available[0]} (only available LLM CLI)')
        return available[0]

    choice = questionary.select(
        'Select LLM for commit message:',
        choices=available,
        default=available[0],
    ).ask()
    if choice is None:
        die('Aborted')
    return choice


def get_commit_log() -> str:
    """Get commit messages between main and develop branches."""
    result = git(
        'log',
        f'{MAIN_BRANCH}..{DEVELOP_BRANCH}',
        '--format=%s%n%b',
        '--no-merges',
        capture=True,
    )
    return result.stdout.strip()


def generate_commit_message(
    llm: str,
    version: str,
    old_version: str,
    commits: str,
) -> str:
    """Generate a commit message using the chosen LLM CLI."""
    prompt = COMMIT_PROMPT_TEMPLATE.format(
        version=version,
        old_version=old_version,
        commits=commits,
    )

    cmd_prefix = LLM_CLIS[llm]
    info(f'Generating commit message with {llm}...')

    result = run(
        [*cmd_prefix, prompt],
        capture=True,
        check=False,
        timeout=120,
    )

    if result.returncode != 0:
        console.print(
            f'[yellow]Warning:[/yellow] {llm} failed: {result.stderr.strip()}'
        )
        return ''

    return result.stdout.strip()


def prompt_message_review(
    message: str,
    llm: str,
    version: str,
    old_version: str,
    commits: str,
) -> str:
    """Show generated message and let user accept, edit, or regenerate."""
    while True:
        console.print()
        console.print(
            Panel(message, title='Generated Commit Message', expand=False)
        )

        action = questionary.select(
            'Commit message action:',
            choices=['Accept', 'Edit', 'Regenerate'],
            default='Accept',
        ).ask()
        if action is None:
            die('Aborted')

        if action == 'Accept':
            return message
        elif action == 'Edit':
            editor = os.environ.get('EDITOR', os.environ.get('VISUAL', ''))
            if editor:
                with tempfile.NamedTemporaryFile(
                    mode='w',
                    suffix='.txt',
                    prefix='release-msg-',
                    delete=False,
                ) as f:
                    f.write(message)
                    tmp_path = f.name
                try:
                    run([editor, tmp_path])
                    with open(tmp_path) as f:
                        message = f.read().strip()
                finally:
                    os.unlink(tmp_path)
            else:
                edited = questionary.text(
                    'Enter commit message:',
                    default=message,
                ).ask()
                if edited is not None:
                    message = edited
        else:
            new_msg = generate_commit_message(
                llm, version, old_version, commits
            )
            if new_msg:
                message = new_msg
            else:
                console.print(
                    '[yellow]Regeneration failed, '
                    'keeping current message[/yellow]'
                )


# ---------------------------------------------------------------------------
# Main release flow
# ---------------------------------------------------------------------------


def parse_args() -> argparse.Namespace:
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(description='Interactive release script')
    parser.add_argument(
        '--test',
        action='store_true',
        help='Test mode: skip dirty-tree check, tox, '
        'and all git write operations',
    )
    return parser.parse_args()


def main() -> None:
    """Run the full interactive release flow."""
    args = parse_args()

    if args.test:
        console.print(
            '[bold yellow]TEST MODE — no changes will be made[/bold yellow]\n'
        )

    # --- Preflight ---
    preflight_checks(dry_run=args.test)

    # --- Version selection ---
    current_version = get_current_version()
    new_version, bump_args = prompt_version_menu(current_version)

    tag = f'v{new_version}'

    # Check tag doesn't already exist
    tag_check = git('rev-parse', tag, capture=True, check=False)
    if tag_check.returncode == 0:
        die(f'Tag {tag} already exists')

    if not args.test:
        # --- Run tests ---
        info('Running tox (all environments)...')
        run(['uvx', '--with', 'tox-uv', 'tox', '-p', 'auto'])
        ok('All test environments passed')

        # --- Bump version ---
        info(f'Bumping version to {new_version}')
        if bump_args is not None:
            actual = apply_bump(bump_args)
        else:
            actual = set_version(new_version)

        if actual != new_version:
            die(
                f'Version mismatch after bump: expected {new_version}, '
                f'got {actual}'
            )
    else:
        info(f'[test] Would bump version to {new_version}')

    # --- Generate commit message ---
    available_llms = detect_llm_clis()
    if available_llms:
        llm = prompt_llm_menu(available_llms)
        commits = get_commit_log()
        if commits:
            message = generate_commit_message(
                llm, new_version, current_version, commits
            )
            if message:
                message = prompt_message_review(
                    message, llm, new_version, current_version, commits
                )
            else:
                console.print(
                    '[yellow]LLM returned empty response, '
                    'using default message[/yellow]'
                )
                message = f'Release {tag}'
        else:
            info('No commits between branches, using default message')
            message = f'Release {tag}'
    else:
        console.print(
            '[yellow]No LLM CLI found (claude, codex, gemini). '
            'Using default commit message.[/yellow]'
        )
        message = f'Release {tag}'

    if args.test:
        console.print()
        console.print(
            Panel(message, title='Final Commit Message', expand=False)
        )
        ok('Test run complete — no changes were made')
        return

    # --- Commit ---
    info('Creating signed commit')
    git('add', 'pyproject.toml')
    git('commit', '-S', '-m', message)

    # --- Merge to main ---
    # origin/main was already fetched and verified in preflight
    info(f'Merging {DEVELOP_BRANCH} into {MAIN_BRANCH} (ff-only)')
    git('checkout', MAIN_BRANCH)
    git('merge', f'origin/{MAIN_BRANCH}', '--ff-only')
    git('merge', DEVELOP_BRANCH, '--ff-only')

    # --- Tag ---
    info(f'Creating signed tag {tag}')
    git('tag', '-s', tag, '-m', f'Release {tag}')

    # --- Push ---
    if not questionary.confirm(
        f'Push {tag} to origin?',
        default=False,
    ).ask():
        git('checkout', DEVELOP_BRANCH)
        die(
            f'Aborted. Tag {tag} and merge are local only — '
            'you can push later or reset.'
        )

    info(f'Pushing {MAIN_BRANCH} + tags')
    git('push', 'origin', MAIN_BRANCH, '--follow-tags')

    # --- Return to develop ---
    git('checkout', DEVELOP_BRANCH)
    git('push', 'origin', DEVELOP_BRANCH)

    ok(
        f'Released {tag}. CI will build wheels, publish to PyPI, '
        'and create GitHub Release.'
    )


if __name__ == '__main__':
    main()
