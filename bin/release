#!/usr/bin/env python3
"""Interactive release script with version bump menu and LLM commit messages."""

from __future__ import annotations

import os
import shutil
import subprocess
import sys
import tempfile

try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.prompt import Prompt
    from rich.table import Table
except ImportError:
    print(
        "Error: 'rich' is required. Install it with:\n"
        "  uv pip install rich\n"
        "  pip install rich",
        file=sys.stderr,
    )
    raise SystemExit(1)

# ---------------------------------------------------------------------------
# Configuration — change these when adopting in another project
# ---------------------------------------------------------------------------

DEVELOP_BRANCH = "develop"
MAIN_BRANCH = "master"

COMMIT_PROMPT_TEMPLATE = """\
Summarize the following git commit messages into a concise release commit
message. The version being released is {version} (previously {old_version}).
Focus on user-facing changes. Use conventional commit style.
Output ONLY the commit message, no extra commentary.

Commits:
{commits}
"""

# ---------------------------------------------------------------------------
# Rich console
# ---------------------------------------------------------------------------

console = Console()

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------


def die(msg: str) -> None:
    """Print a red error message and exit."""
    console.print(f"[bold red]Error:[/bold red] {msg}", highlight=False)
    raise SystemExit(1)


def info(msg: str) -> None:
    """Print a blue info message."""
    console.print(f"[bold blue]==>[/bold blue] {msg}", highlight=False)


def ok(msg: str) -> None:
    """Print a green success message."""
    console.print(f"[bold green]==>[/bold green] {msg}", highlight=False)


# ---------------------------------------------------------------------------
# Subprocess helpers
# ---------------------------------------------------------------------------


def run(
    cmd: list[str],
    *,
    capture: bool = False,
    check: bool = True,
    stdin_data: str | None = None,
    timeout: int | None = None,
) -> subprocess.CompletedProcess[str]:
    """Run a command via subprocess."""
    return subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
        check=check,
        input=stdin_data,
        timeout=timeout,
    )


def git(*args: str, capture: bool = False) -> subprocess.CompletedProcess[str]:
    """Run a git command."""
    return run(["git", *args], capture=capture)


def uv(*args: str, capture: bool = False) -> subprocess.CompletedProcess[str]:
    """Run a uv command."""
    return run(["uv", *args], capture=capture)


# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------


def preflight_checks() -> None:
    """Validate branch, working tree, and tool availability."""
    # Check uv is available
    if not shutil.which("uv"):
        die("'uv' is not installed or not in PATH")

    # Check branch
    result = git("symbolic-ref", "--short", "HEAD", capture=True)
    branch = result.stdout.strip()
    if branch != DEVELOP_BRANCH:
        die(
            f"Must be on '{DEVELOP_BRANCH}' branch "
            f"(currently on '{branch}')"
        )

    # Check clean working tree
    diff_result = run(
        ["git", "diff", "--quiet"],
        check=False,
    )
    cached_result = run(
        ["git", "diff", "--cached", "--quiet"],
        check=False,
    )
    if diff_result.returncode != 0 or cached_result.returncode != 0:
        die("Working tree is dirty — commit or stash changes first")


# ---------------------------------------------------------------------------
# Version helpers
# ---------------------------------------------------------------------------


def get_current_version() -> str:
    """Read current version from pyproject.toml via uv."""
    result = uv("version", "--short", capture=True)
    return result.stdout.strip()


def preview_bump(bump_args: list[str]) -> str:
    """Preview what version a bump would produce, without writing.

    Returns the new version string.
    Raises SystemExit if the bump combination is invalid.
    """
    cmd = ["uv", "version"]
    for arg in bump_args:
        cmd.extend(["--bump", arg])
    cmd.append("--dry-run")

    result = run(cmd, capture=True, check=False)
    if result.returncode != 0:
        # uv prints the error to stderr
        die(f"Invalid version bump: {result.stderr.strip()}")

    # Output format: "package X.Y.Z => A.B.C"
    line = result.stdout.strip()
    return line.split("=>")[-1].strip()


def apply_bump(bump_args: list[str]) -> str:
    """Apply a version bump and return the new version."""
    cmd = ["uv", "version"]
    for arg in bump_args:
        cmd.extend(["--bump", arg])
    cmd.append("--frozen")

    result = run(cmd, capture=True, check=False)
    if result.returncode != 0:
        die(f"Version bump failed: {result.stderr.strip()}")

    # Read back the actual version to confirm
    return get_current_version()


def set_version(version: str) -> str:
    """Set an explicit version string (for custom input)."""
    uv("version", version, "--frozen", capture=True)
    return get_current_version()


# ---------------------------------------------------------------------------
# Interactive version menu
# ---------------------------------------------------------------------------


def prompt_prerelease_menu(current: str) -> tuple[str, list[str]]:
    """Sub-menu for pre-release version selection.

    Returns (new_version, bump_args).
    """
    # Pick component
    console.print()
    console.print("[bold]Bump component:[/bold]")
    console.print("  [cyan]1[/cyan]  Major")
    console.print("  [cyan]2[/cyan]  Minor")
    console.print("  [cyan]3[/cyan]  Patch")
    component_choice = Prompt.ask(
        "\nComponent",
        choices=["1", "2", "3"],
        default="2",
    )
    component_map = {"1": "major", "2": "minor", "3": "patch"}
    component = component_map[component_choice]

    # Pick pre-release type
    console.print()
    console.print("[bold]Pre-release type:[/bold]")
    console.print("  [cyan]a[/cyan]  rc  (release candidate)")
    console.print("  [cyan]b[/cyan]  beta")
    console.print("  [cyan]c[/cyan]  alpha")
    type_choice = Prompt.ask(
        "\nType",
        choices=["a", "b", "c"],
        default="a",
    )
    type_map = {"a": "rc", "b": "beta", "c": "alpha"}
    pre_type = type_map[type_choice]

    bump_args = [component, pre_type]
    new_version = preview_bump(bump_args)

    console.print(
        f"\n  Preview: [bold]{current}[/bold] → [bold green]{new_version}[/bold green]"
    )

    return new_version, bump_args


def prompt_version_menu(current: str) -> tuple[str, list[str] | None]:
    """Present the main version bump menu.

    Returns (new_version, bump_args).
    bump_args is None when a custom version string was entered.
    """
    # Compute previews for standard bumps
    major_v = preview_bump(["major"])
    minor_v = preview_bump(["minor"])
    patch_v = preview_bump(["patch"])

    table = Table(
        show_header=False,
        box=None,
        padding=(0, 2),
    )
    table.add_column(style="cyan", width=4)
    table.add_column(width=16)
    table.add_column(style="dim", width=3)
    table.add_column(style="bold green")

    table.add_row("1", "Major", "→", major_v)
    table.add_row("2", "Minor", "→", minor_v)
    table.add_row("3", "Patch", "→", patch_v)
    table.add_row("4", "Pre-release", "→", "(submenu)")
    table.add_row("5", "Custom", "→", "(enter version)")

    console.print()
    console.print(f"  Current version: [bold]{current}[/bold]")
    console.print()
    console.print(Panel(table, title="Version Bump", expand=False))

    choice = Prompt.ask(
        "Select",
        choices=["1", "2", "3", "4", "5"],
        default="2",
    )

    if choice == "1":
        return major_v, ["major"]
    elif choice == "2":
        return minor_v, ["minor"]
    elif choice == "3":
        return patch_v, ["patch"]
    elif choice == "4":
        return prompt_prerelease_menu(current)
    else:
        # Custom version
        custom = Prompt.ask("Enter PEP 440 version")
        # Validate by doing a dry-run set
        cmd = ["uv", "version", custom, "--dry-run"]
        result = run(cmd, capture=True, check=False)
        if result.returncode != 0:
            die(f"Invalid version: {result.stderr.strip()}")
        return custom, None
